# Copy to .env on the metrics host and replace placeholders.
BASE_DOMAIN=example.com
PUBLIC_STATUS_HOST=status.example.com
PUBLIC_API_HOST=api-status.example.com
STATUS_GATEWAY_BIND=127.0.0.1
PROMETHEUS_RETENTION=30d

# Write token. Enrolls devices, accepts status reports, and registers scrape
# targets. Only the phone app and scripts/operator/register-device.py need it.
STATUS_INGEST_TOKEN=replace-with-generated-token

# Read token. Grants the /internal dashboard, the metric query proxy, and scrape
# discovery — nothing else. Never reuse the ingest token here: this value is
# pasted into a browser and kept in localStorage.
# Prometheus presents the same token, so also write it, without a trailing
# newline, to prometheus/query_token before the first `docker compose up`:
#   printf %s "<the token>" > prometheus/query_token
STATUS_QUERY_TOKEN=replace-with-a-second-generated-token

GITHUB_TOKEN=replace-with-github-user-scope-token
GITHUB_STATUS_MIN_INTERVAL_SECONDS=10
GITHUB_STATUS_TTL_MINUTES=20
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
