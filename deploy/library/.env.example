# Copy this file to /etc/cloud-drive/runtime.env on the deployment host, replace
# every REPLACE_* value, then set ownership to root:root and mode to 0600.
# Values must be single-line and unquoted. This file is intentionally safe to commit.

COMPOSE_PROJECT_NAME=cloud-drive

# Override with approved digests after an image review.
POSTGRES_IMAGE=postgres:18.4-alpine
CLOUD_DRIVE_IMAGE=cloud-drive:local

POSTGRES_DB=cloud_drive
POSTGRES_USER=cloud_drive
# Generate with: openssl rand -hex 32
# Keep this URL-safe because Compose constructs DATABASE_URL from it.
POSTGRES_PASSWORD=REPLACE_WITH_A_64_CHARACTER_HEX_VALUE

# These directories are created by deploy/library/scripts/initialize-storage.sh.
CLOUD_DRIVE_VOLUME_MOUNT_DIR=/srv/cloud-drive/data
CLOUD_DRIVE_DATA_DIR=/srv/cloud-drive/data/files
CLOUD_DRIVE_POSTGRES_DIR=/srv/cloud-drive/data/postgres
CLOUD_DRIVE_BACKUP_STAGING_DIR=/srv/cloud-drive/data/backup-staging

# Encrypts only third-party account credentials, not media files.
# Generate with: openssl rand -base64 32
MUSIC_PROVIDER_CREDENTIAL_KEY=REPLACE_WITH_A_32_BYTE_PADDED_BASE64_VALUE
# API uploads and provider downloads both preserve this much free local space.
RESERVED_FREE_BYTES=21474836480

# The public Site owns anonymous shares and wallpapers. The authenticated
# Console owns all private Library screens and provider callback returns.
PUBLIC_SITE_ORIGIN=https://me.example.com
CONSOLE_ORIGIN=https://console.realtime.internal:9443

# The common owner access-token audience is shared by Status, Library, and Manager.
OIDC_ISSUER=https://identity.example.com/realms/realtime-me
LIBRARY_AUTH_AUDIENCE=realtime-me
PRIVATE_API_HOST=REPLACE_WITH_LIBRARY_HOST_LAN_IP
PUBLIC_API_HOST=REPLACE_WITH_PUBLIC_API_HOST

# Use this host's existing static LAN address; do not claim a new address.
LIBRARY_API_LAN_BIND=REPLACE_WITH_LIBRARY_HOST_LAN_IP
# Dedicated overlay address used only by remote OpenVPN clients.
LIBRARY_API_VPN_BIND=10.66.0.11
# Root-owned 0400 file shared across the management plane.
INTERNAL_API_KEY_FILE=/etc/realtime-me/internal-api-key

# Optional. Leave both empty until a Spotify developer application is ready.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
