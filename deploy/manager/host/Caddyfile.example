{
	admin off
	auto_https disable_redirects
}

https://manager.realtime.internal {
	# Split DNS resolves this name to the existing LAN address locally and
	# 10.66.0.1 through OpenVPN. Neither listener is routed from the Internet.
	bind {$MANAGER_LAN_ADDRESS} 10.66.0.1
	tls /etc/caddy/super-manager/server.cert.pem /etc/caddy/super-manager/server.key.pem {
		client_auth {
			mode require_and_verify
			trust_pool file /etc/caddy/super-manager/ca.cert.pem
		}
	}

	@pairing path /realtime.me.manager.control.v1.PairingService/PairDevice
	respond @pairing 404

	reverse_proxy 127.0.0.1:3080 {
		header_up -X-Realtime-Internal-Key
		flush_interval -1
		stream_close_delay 5m
	}
}

https://manager.realtime.internal:8443 {
	bind {$MANAGER_LAN_ADDRESS} 10.66.0.1
	tls /etc/caddy/super-manager/server.cert.pem /etc/caddy/super-manager/server.key.pem

	@pairing {
		method POST
		path /realtime.me.manager.control.v1.PairingService/PairDevice
	}
	handle @pairing {
		reverse_proxy 127.0.0.1:3080 {
			header_up -X-Realtime-Internal-Key
			flush_interval -1
		}
	}
	respond 404
}

https://console.realtime.internal:9443 {
	# The same hostname uses split DNS: LAN -> MANAGER_LAN_ADDRESS,
	# VPN -> 10.66.0.1.
	bind {$MANAGER_LAN_ADDRESS} 10.66.0.1
	tls internal

	reverse_proxy 127.0.0.1:8090 {
		flush_interval -1
		stream_close_delay 5m
	}
}
