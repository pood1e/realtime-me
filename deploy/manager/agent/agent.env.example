NODE_ENV=production
SM_HOST=127.0.0.1
SM_PORT=3080
SM_LOG_LEVEL=info
SM_DATA_DIR=/var/lib/super-manager/data
SM_ALLOWED_WORKSPACE_ROOTS=/srv/workspaces
SM_CODEX_PATH=/opt/super-manager/providers/node_modules/.bin/codex
SM_CODEX_VERSION=0.144.5
SM_CLAUDE_PATH=/opt/super-manager/providers/node_modules/.bin/claude
SM_CLAUDE_VERSION=2.1.195
SM_TMUX_PATH=/usr/bin/tmux
SM_TMUX_SOCKET_NAME=super-manager
SM_OPENSSL_PATH=/usr/bin/openssl
SM_PUBLIC_URL=https://manager.example.com
SM_PAIRING_URL=https://manager.example.com:8443
OIDC_ISSUER=https://identity.example.com/realms/realtime-me
MANAGER_AUTH_AUDIENCE=realtime-me
HOME=/var/lib/super-manager
