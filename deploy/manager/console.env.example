# Install as /etc/realtime-me/console.env with root:root mode 0600.
CONSOLE_LISTEN_ADDRESS=127.0.0.1:8090
CONSOLE_PUBLIC_ORIGIN=https://console.realtime.internal:9443
CONSOLE_WEB_DIR=/opt/realtime-me/apps/web/console/dist

# Cleartext upstreams are accepted only as literal addresses inside these
# private ranges. The systemd unit supplies INTERNAL_API_KEY_FILE as a credential.
MANAGEMENT_CIDRS=192.168.0.0/24

OIDC_ISSUER=https://identity.example.com/realms/realtime-me
OIDC_CLIENT_ID=realtime-me-console
OIDC_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET
# Add provider-specific scopes here only when required; request offline_access explicitly
# only when the provider's refresh-token policy needs it.
OIDC_SCOPES=

# Console reaches Status and Library from the Manager host over their existing
# LAN addresses. OpenVPN clients never receive a route for this LAN subnet.
STATUS_UPSTREAM=http://REPLACE_WITH_STATUS_HOST_LAN_IP:18080
LIBRARY_UPSTREAM=http://REPLACE_WITH_LIBRARY_HOST_LAN_IP:18081
MANAGER_UPSTREAM=http://127.0.0.1:3080
