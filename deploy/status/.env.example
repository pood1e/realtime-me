# Copy to .env on the metrics host.
#
# This holds only what Docker Compose itself has to interpolate. Compose cannot read
# gateway.yaml, and gateway.yaml is where every setting the gateway reads now lives —
# so if you are looking for the tokens, the GitHub credentials, or the profile, they
# are there, not here. BASE_DOMAIN, PUBLIC_STATUS_HOST and PUBLIC_API_HOST used to sit
# in this file and were read by nothing at all; they are gone.

# Use this host's existing static LAN address; do not claim a new address.
STATUS_GATEWAY_LAN_BIND=REPLACE_WITH_STATUS_HOST_LAN_IP
# The Status client's dedicated OpenVPN address. Remote networks route only
# 10.66.0.0/24, so another site's 192.168.0.0/24 cannot conflict.
STATUS_GATEWAY_VPN_BIND=10.66.0.10

# Root-owned 0400 file shared with Console, Manager, and Library.
# Generate once with: openssl rand -hex 32
INTERNAL_API_KEY_FILE=/etc/realtime-me/internal-api-key

# How long Prometheus keeps its time series.
PROMETHEUS_RETENTION=30d

# Human Console access. Use the same access-token audience for every service;
# service-specific permissions remain separate claims.
OIDC_ISSUER=https://identity.example.com/realms/realtime-me
STATUS_AUTH_AUDIENCE=realtime-me
