{
  "name": "cloud-drive",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build:web": "pnpm --recursive --if-present build",
    "typecheck:web": "pnpm --recursive --if-present typecheck",
    "dev:private": "pnpm --filter @cloud-drive/private-portal dev",
    "dev:share": "pnpm --filter @cloud-drive/share-portal dev"
  },
  "devDependencies": {
    "vite": "8.1.3",
    "wrangler": "^4.110.0"
  }
}
