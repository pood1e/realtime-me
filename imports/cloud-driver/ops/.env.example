# Copy this file to /etc/cloud-drive/runtime.env on the deployment host, replace
# every REPLACE_* value, then set ownership to root:root and mode to 0600.
# Values must be single-line and unquoted. This file is intentionally safe to commit.

COMPOSE_PROJECT_NAME=cloud-drive

# Override with approved digests after an image review.
POSTGRES_IMAGE=postgres:18.4-alpine
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.6.0
CLOUD_DRIVE_IMAGE=cloud-drive:local

POSTGRES_DB=cloud_drive
POSTGRES_USER=cloud_drive
# Generate with: openssl rand -hex 32
# Keep this URL-safe because Compose constructs DATABASE_URL from it.
POSTGRES_PASSWORD=REPLACE_WITH_A_64_CHARACTER_HEX_VALUE

# These directories are created by ops/scripts/initialize-storage.sh.
CLOUD_DRIVE_VOLUME_MOUNT_DIR=/srv/cloud-drive/data
CLOUD_DRIVE_DATA_DIR=/srv/cloud-drive/data/files
CLOUD_DRIVE_POSTGRES_DIR=/srv/cloud-drive/data/postgres
CLOUD_DRIVE_BACKUP_STAGING_DIR=/srv/cloud-drive/data/backup-staging

# Path to a separate root-only file containing only the remote-managed Tunnel
# token. The token must never be placed in this Compose environment file.
CLOUDFLARE_TUNNEL_TOKEN_FILE=/etc/cloud-drive/cloudflare-tunnel.token

# Single-owner password authentication. Store only a Base64-encoded bcrypt
# hash, never the plaintext password. Use bcrypt cost 12 or greater.
PASSWORD_HASH_BASE64=REPLACE_WITH_BASE64_ENCODED_BCRYPT_HASH
# Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_A_64_CHARACTER_HEX_VALUE
# Encrypts only third-party account credentials, not media files.
# Generate with: openssl rand -base64 32
MUSIC_PROVIDER_CREDENTIAL_KEY=REPLACE_WITH_A_32_BYTE_PADDED_BASE64_VALUE
# API uploads and provider downloads both preserve this much free local space.
RESERVED_FREE_BYTES=21474836480

# Comma-separated exact origins. Keep authentication and all four private peer
# applications in PRIVATE_APP_ORIGINS; keep the two anonymous applications in
# PUBLIC_APP_ORIGINS.
PRIVATE_APP_ORIGINS=REPLACE_WITH_AUTH_ORIGIN,REPLACE_WITH_DRIVE_ORIGIN,REPLACE_WITH_BOOKS_ORIGIN,REPLACE_WITH_MUSIC_ORIGIN,REPLACE_WITH_IMAGES_ORIGIN
PUBLIC_APP_ORIGINS=REPLACE_WITH_WALLPAPERS_ORIGIN,REPLACE_WITH_SHARE_ORIGIN
SHARE_APP_ORIGIN=REPLACE_WITH_HTTPS_SHARE_APP_ORIGIN
MUSIC_APP_ORIGIN=REPLACE_WITH_HTTPS_MUSIC_APP_ORIGIN
PRIVATE_API_HOST=REPLACE_WITH_PRIVATE_API_HOST
PUBLIC_API_HOST=REPLACE_WITH_PUBLIC_API_HOST

# Optional. Leave both empty until a Spotify developer application is ready.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
