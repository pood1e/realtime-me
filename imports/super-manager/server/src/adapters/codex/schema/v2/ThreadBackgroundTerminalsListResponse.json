        "command": {
          "type": "string"
        },
        "cpuPercent": {
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "cwd": {
          "$ref": "#/definitions/AbsolutePathBuf"
        },
        "itemId": {
          "type": "string"
        },
        "osPid": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "processId": {
          "type": "string"
        },
        "rssKb": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "command",
        "cwd",
        "itemId",
        "processId"
      ],
      "type": "object"
    }
  },
  "properties": {
