{
  "name": "super-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "pnpm --filter @super-manager/server build",
    "check": "pnpm lint:proto && pnpm --filter @super-manager/server check",
    "format": "biome format --write . && buf format -w",
    "generate": "buf generate && node tools/normalize-dart-generated.mjs",
    "lint:proto": "buf lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4"
  }
}
